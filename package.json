{
  "name": "astrbot-live2d-desktop",
  "version": "1.1.0-beta.13",
  "description": "AstrBot Live2D 桌面应用",
  "main": "dist-electron/main.js",
  "type": "module",
  "author": "lxfight <1686540385@qq.com>",
  "license": "MIT",
  "keywords": [
    "electron",
    "vue3",
    "live2d",
    "astrbot"
  ],
  "cubism": {
    "sdkBaseline": "5-r.4",
    "frameworkRepo": "https://github.com/Live2D/CubismWebFramework.git",
    "frameworkTag": "5-r.4",
    "frameworkCommit": "8df84780f2aa1298f3b30965cdae143e049f3c8e",
    "samplesRepo": "https://github.com/Live2D/CubismWebSamples.git",
    "samplesTag": "5-r.4",
    "samplesCommit": "435707a4676c19de754a8a557638450f889dcd2c",
    "core": {
      "filename": "live2dcubismcore.min.js",
      "downloadUrl": "https://cubism.live2d.com/sdk-web/cubismcore/live2dcubismcore.min.js",
      "runtimeSource": "official-sdk-download"
    }
  },
  "scripts": {
    "dev": "vite",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "vue-tsc --noEmit",
    "preview": "vite preview",
    "clean": "node -e \"const fs=require('fs');['release','dist','dist-electron'].forEach(p=>fs.existsSync(p)&&fs.rmSync(p,{recursive:true,force:true}));\"",
    "rebuild": "node scripts/rebuild-native.js",
    "rebuild:optional": "node scripts/rebuild-native.js --optional",
    "cubism:patch": "node scripts/apply-cubism-framework-patches.mjs",
    "postinstall": "node scripts/rebuild-native.js --optional && node scripts/download-cubism-core.js && node scripts/download-framework.js && node scripts/apply-cubism-framework-patches.mjs",
    "setup:framework": "node scripts/download-framework.js",
    "setup:framework:force": "node scripts/download-framework.js --force",
    "rebuild:electron": "electron-rebuild -f -w extract-file-icon,node-window-manager,better-sqlite3",
    "build:prepare": "pnpm run typecheck && pnpm exec vite build",
    "build:prepare:fast": "pnpm exec vite build",
    "pack": "pnpm exec electron-builder --publish never",
    "pack:dir": "pnpm exec electron-builder --dir --publish never",
    "pack:win": "pnpm exec electron-builder --win --publish never",
    "pack:mac": "pnpm exec electron-builder --mac --publish never",
    "pack:linux": "pnpm exec electron-builder --linux --publish never",
    "build": "pnpm run build:prepare && pnpm run rebuild:optional && pnpm run pack",
    "build:dir": "pnpm run build:prepare && pnpm run rebuild:optional && pnpm run pack:dir",
    "build:win": "pnpm run build:prepare && pnpm run rebuild:optional && pnpm run pack:win",
    "build:mac": "pnpm run build:prepare && pnpm run rebuild:optional && pnpm run pack:mac",
    "build:linux": "pnpm run build:prepare && pnpm run rebuild:optional && pnpm run pack:linux",
    "build:fast": "pnpm run build:prepare:fast && pnpm run pack:dir",
    "build:ci:win": "pnpm run build:prepare && pnpm run pack:win",
    "build:ci:mac": "pnpm run build:prepare && pnpm run pack:mac",
    "build:ci:linux": "pnpm run build:prepare && pnpm run pack:linux"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.10.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.10",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vue/language-core": "^3.2.4",
    "concurrently": "^8.2.0",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "sass": "^1.69.0",
    "sass-embedded": "^1.97.3",
    "typescript": "^5.3.0",
    "vite": "^5.4.0",
    "vite-plugin-electron": "^0.28.0",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.4",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "@vueuse/core": "^10.7.0",
    "active-win": "^8.2.1",
    "axios": "^1.6.0",
    "better-sqlite3": "^9.2.0",
    "colorthief": "^2.6.0",
    "date-fns": "^3.0.0",
    "dompurify": "^3.3.2",
    "echarts": "^5.4.0",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.8.3",
    "extract-file-icon": "^0.3.2",
    "howler": "^2.2.3",
    "katex": "^0.16.28",
    "lucide-vue-next": "^0.563.0",
    "marked": "^17.0.1",
    "naive-ui": "^2.37.0",
    "node-addon-api": "^2.0.0",
    "node-gyp-build": "^4.8.4",
    "node-vibrant": "^4.0.4",
    "pinia": "^2.1.0",
    "simplex-noise": "^4.0.3",
    "uuid": "^9.0.0",
    "vue": "^3.4.0",
    "vue-router": "^4.2.0",
    "ws": "^8.16.0"
  },
  "optionalDependencies": {
    "node-window-manager": "^2.2.4"
  },
  "build": {
    "appId": "com.astrbot.live2d.desktop",
    "productName": "AstrBot Live2D Desktop",
    "directories": {
      "output": "release",
      "buildResources": "resources"
    },
    "extraResources": [
      {
        "from": "resources/icon.ico",
        "to": "icon.ico"
      },
      {
        "from": "resources/icon.png",
        "to": "icon.png"
      }
    ],
    "asar": true,
    "npmRebuild": false,
    "files": [
      "dist/**",
      "dist-electron/**",
      "node_modules/active-win/package.json",
      "node_modules/active-win/index.js",
      "node_modules/active-win/index.d.ts",
      "node_modules/active-win/lib/**",
      "node_modules/better-sqlite3/package.json",
      "node_modules/better-sqlite3/lib/**",
      "node_modules/better-sqlite3/build/Release/*.node",
      "node_modules/node-window-manager/package.json",
      "node_modules/node-window-manager/dist/**",
      "node_modules/node-window-manager/build/Release/*.node",
      "node_modules/extract-file-icon/package.json",
      "node_modules/extract-file-icon/dist/**",
      "node_modules/extract-file-icon/build/Release/*.node",
      "node_modules/node-gyp-build/**",
      "node_modules/node-addon-api/**",
      "package.json",
      "!dist/models/**/.git/**",
      "!dist/models/**/.svn/**",
      "!dist/models/**/node_modules/**",
      "!dist/models/**/{test,tests,__tests__,example,examples}/**",
      "!dist/models/package.json/**",
      "!dist/models/temp/**",
      "!dist/wakeword/**",
      "!**/*.map",
      "!**/*.ts",
      "!**/*.tsx",
      "!**/*.vue",
      "!**/*.md",
      "!**/*.log",
      "!**/node_modules/*/{test,tests,__tests__,docs,doc,example,examples}/**",
      "!**/node_modules/.cache/**"
    ],
    "asarUnpack": [
      "**/*.node"
    ],
    "artifactName": "astrbot-live2d-desktop-v${version}-${os}-${arch}.${ext}",
    "publish": [
      {
        "provider": "github",
        "owner": "lxfight",
        "repo": "astrbot-live2d-desktop"
      }
    ],
    "win": {
      "icon": "icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AstrBot Live2D Desktop",
      "deleteAppDataOnUninstall": false
    },
    "portable": {
      "artifactName": "astrbot-live2d-desktop-v${version}-portable-${arch}.${ext}"
    },
    "compression": "maximum",
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "rpm"
      ],
      "category": "Utility",
      "maintainer": "lxfight <1686540385@qq.com>",
      "desktop": {
        "StartupNotify": "true"
      }
    }
  }
}
